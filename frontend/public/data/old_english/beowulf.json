{
  "title": "Beowulf",
  "date": "c. 700–1000 CE",
  "manuscript": "British Library, Cotton Vitellius A.xv",
  "sections": [
    {
      "id": "fitt-1",
      "num": "I",
      "title": "The Spear-Danes",
      "lineStart": 1,
      "lineEnd": 52,
      "lines": [
        {
          "num": 1,
          "a": "Hwæt! We Gardena",
          "b": "in geardagum,",
          "translation": "Listen! We have heard of the glory of the Spear-Danish kings in days of old,"
        },
        {
          "num": 2,
          "a": "þeodcyninga",
          "b": "þrym gefrunon,",
          "translation": "how those princes performed deeds of courage."
        },
        {
          "num": 3,
          "a": "hu ða æþelingas",
          "b": "ellen fremedon.",
          "translation": "How the princes performed deeds of valor!"
        },
        {
          "num": 4,
          "a": "Oft Scyld Scefing",
          "b": "sceaþena þreatum,",
          "translation": "Often Scyld Scefing seized mead-benches from enemy troops,"
        },
        {
          "num": 5,
          "a": "monegum mægþum",
          "b": "meodosetla ofteah,",
          "translation": "from many tribes. He terrified nobles."
        },
        {
          "num": 6,
          "a": "egsode eorlas.",
          "b": "Syððan ærest wearð",
          "translation": "He struck fear into earls. After first he was"
        },
        {
          "num": 7,
          "a": "feasceaft funden,",
          "b": "he þæs frofre gebad,",
          "translation": "found destitute, he lived to find comfort for that —"
        },
        {
          "num": 8,
          "a": "weox under wolcnum,",
          "b": "weorðmyndum þah,",
          "translation": "he grew under the sky, thrived in honors,"
        },
        {
          "num": 9,
          "a": "oðþæt him æghwylc",
          "b": "þara ymbsittendra",
          "translation": "until every one of the neighboring peoples"
        },
        {
          "num": 10,
          "a": "ofer hronrade",
          "b": "hyran scolde,",
          "translation": "across the whale-road had to obey him,"
        },
        {
          "num": 11,
          "a": "gomban gyldan.",
          "b": "þæt wæs god cyning!",
          "translation": "to pay him tribute. That was a good king!"
        },
        {
          "num": 12,
          "a": "ðæm eafera wæs",
          "b": "æfter cenned,",
          "translation": "A son was born to him in the courts afterwards,"
        },
        {
          "num": 13,
          "a": "geong in geardum,",
          "b": "þone god sende",
          "translation": "young in the strongholds — whom God sent"
        },
        {
          "num": 14,
          "a": "folce to frofre;",
          "b": "fyrenðearfe ongeat",
          "translation": "as a comfort to the people. God had perceived the grievous need"
        },
        {
          "num": 15,
          "a": "þe hie ær drugon",
          "b": "aldorlease",
          "translation": "that they had previously endured, leaderless"
        },
        {
          "num": 16,
          "a": "lange hwile.",
          "b": "Him þæs liffrea,",
          "translation": "for a long while. The Lord of life,"
        },
        {
          "num": 17,
          "a": "wuldres wealdend,",
          "b": "woroldare forgeaf;",
          "translation": "the Ruler of glory, gave him worldly honor."
        },
        {
          "num": 18,
          "a": "Beowulf wæs breme —",
          "b": "blæd wide sprang —",
          "translation": "Beowulf was renowned — his fame spread far —"
        },
        {
          "num": 19,
          "a": "Scyldes eafera",
          "b": "Scedelandum in.",
          "translation": "Scyld's son, in the Scede-lands."
        },
        {
          "num": 20,
          "a": "Swa sceal geong guma",
          "b": "gode gewyrcean,",
          "translation": "So must a young man bring about good through generous gifts,"
        },
        {
          "num": 21,
          "a": "fromum feohgiftum",
          "b": "on fæder bearme,",
          "translation": "with fine treasures, while in his father's keeping,"
        },
        {
          "num": 22,
          "a": "þæt hine on ylde",
          "b": "eft gewunigen",
          "translation": "so that in old age his dear companions will stand by him in turn,"
        },
        {
          "num": 23,
          "a": "wilgesiþas,",
          "b": "þonne wig cume,",
          "translation": "his beloved retainers, when war comes;"
        },
        {
          "num": 24,
          "a": "leode gelæsten;",
          "b": "lofdædum sceal",
          "translation": "a man shall prosper among a people through deeds of praise"
        },
        {
          "num": 25,
          "a": "in mægþa gehwære",
          "b": "man geþeon.",
          "translation": "in every tribe."
        },
        {
          "num": 26,
          "a": "Him ða Scyld gewat",
          "b": "to gescæphwile",
          "translation": "Then Scyld departed at his fated hour,"
        },
        {
          "num": 27,
          "a": "felahror feran",
          "b": "on frean wære.",
          "translation": "the mighty one journeyed into the Lord's keeping."
        },
        {
          "num": 28,
          "a": "Hi hyne þa ætbæron",
          "b": "to brimes faroðe,",
          "translation": "His beloved companions then carried him to the sea's current,"
        },
        {
          "num": 29,
          "a": "swæse gesiþas,",
          "b": "swa he selfa bæd,",
          "translation": "his dear retainers, as he himself had bidden,"
        },
        {
          "num": 30,
          "a": "þenden wordum weold",
          "b": "wine Scyldinga;",
          "translation": "while words held power — the friend of the Scyldings."
        },
        {
          "num": 31,
          "a": "leof landfruma",
          "b": "lange ahte.",
          "translation": "The beloved lord of the land had long ruled."
        },
        {
          "num": 32,
          "a": "þær æt hyðe stod",
          "b": "hringedstefna,",
          "translation": "There at the harbor stood a ring-prowed ship,"
        },
        {
          "num": 33,
          "a": "isig ond utfus,",
          "b": "æþelinges fær.",
          "translation": "icy and eager to depart — a prince's vessel."
        },
        {
          "num": 34,
          "a": "Aledon þa leofne þeoden,",
          "b": "beaga brytten, on bearm scipes,",
          "translation": "They laid the beloved lord, the giver of rings, in the ship's bosom,"
        },
        {
          "num": 35,
          "a": "mærne be mæste.",
          "b": "þær wæs madma fela",
          "translation": "the glorious one by the mast. There was many a treasure,"
        },
        {
          "num": 36,
          "a": "of feorwegum",
          "b": "frætwa gelæded;",
          "translation": "from distant roads, fine ornaments loaded there."
        },
        {
          "num": 37,
          "a": "ne hyrde ic cymlicor",
          "b": "ceol gegyrwan",
          "translation": "I have not heard of a ship more splendidly fitted out"
        },
        {
          "num": 38,
          "a": "hildewæpnum",
          "b": "ond heaðowadum,",
          "translation": "with battle-weapons and war-garments,"
        },
        {
          "num": 39,
          "a": "billum ond byrnum;",
          "b": "him on bearme læg",
          "translation": "with swords and mail-coats. In his lap lay"
        },
        {
          "num": 40,
          "a": "madma mænigo,",
          "b": "þa him mid scoldon",
          "translation": "a multitude of treasures, which were to travel with him"
        },
        {
          "num": 41,
          "a": "on flodes æht",
          "b": "feor gewitan.",
          "translation": "far away into the keeping of the flood."
        },
        {
          "num": 42,
          "a": "Nalæs hi hine læssan lacum teodan,",
          "b": "þeodgesteonum,",
          "translation": "By no means did they furnish him with lesser gifts, with national treasures,"
        },
        {
          "num": 43,
          "a": "þon þa dydon",
          "b": "þe hine æt frumsceafte",
          "translation": "than those who had at his creation"
        },
        {
          "num": 44,
          "a": "forð onsendon",
          "b": "ænne ofer yðe umborwesende.",
          "translation": "sent him forth alone over the waves when he was an infant."
        },
        {
          "num": 45,
          "a": "þa gyt hie him asetton",
          "b": "segen gyllenne",
          "translation": "Then they set up for him a golden banner,"
        },
        {
          "num": 46,
          "a": "heah ofer heafod,",
          "b": "leton holm beran,",
          "translation": "high over his head, and let the sea bear him,"
        },
        {
          "num": 47,
          "a": "geafon on garsecg;",
          "b": "him wæs geomor sefa,",
          "translation": "gave him to the ocean. Their spirits were mournful,"
        },
        {
          "num": 48,
          "a": "murnende mod.",
          "b": "Men ne cunnon",
          "translation": "their hearts grieving. Men cannot"
        },
        {
          "num": 49,
          "a": "secgan to soþe,",
          "b": "seleræedende,",
          "translation": "say truly — hall-counselors,"
        },
        {
          "num": 50,
          "a": "hæleð under heofenum,",
          "b": "hwæm þæm hlæste onfeng.",
          "translation": "heroes under the heavens — who received that cargo."
        }
      ]
    },
    {
      "id": "fitt-2",
      "num": "II",
      "title": "Heorot",
      "lineStart": 53,
      "lineEnd": 114,
      "lines": [
        {
          "num": 53,
          "a": "ða wæs on burgum",
          "b": "Beowulf Scyldinga,",
          "translation": "Then among peoples Beowulf of the Scyldings was renowned —"
        },
        {
          "num": 54,
          "a": "leof leodcyning,",
          "b": "longe þrage",
          "translation": "a beloved people-king — for a long time."
        },
        {
          "num": 55,
          "a": "folcum gefræge",
          "b": "(fæder ellor hwearf,",
          "translation": "Famous among peoples — his father departed elsewhere,"
        },
        {
          "num": 56,
          "a": "aldor of earde),",
          "b": "oðþæt him eft onwoc",
          "translation": "lord from the land — until there awoke to him in turn"
        },
        {
          "num": 57,
          "a": "heah Healfdene;",
          "b": "heold þenden lifde,",
          "translation": "great Healfdene. He held for as long as he lived,"
        },
        {
          "num": 58,
          "a": "gamol ond guðreouw,",
          "b": "glæde Scyldingas.",
          "translation": "old and fierce in battle, the glad Scyldings."
        },
        {
          "num": 59,
          "a": "ðæm feower bearn",
          "b": "forð gerimed",
          "translation": "To him four children were counted in succession,"
        },
        {
          "num": 60,
          "a": "in worold wocun,",
          "b": "weoroda ræswa,",
          "translation": "born into the world — a leader of hosts:"
        },
        {
          "num": 61,
          "a": "Heorogar ond Hrothgar",
          "b": "ond Halga til;",
          "translation": "Heorogar and Hrothgar and good Halga;"
        },
        {
          "num": 62,
          "a": "hyrde ic þæt",
          "b": "wæs Onelan cwen,",
          "translation": "I have heard that the wife of Onela was —"
        },
        {
          "num": 63,
          "a": "Heaðoscilfingas",
          "b": "healsgebedda.",
          "translation": "a Scylfing woman, his beloved bed-companion."
        },
        {
          "num": 64,
          "a": "þa wæs Hrothgare",
          "b": "heresped gyfen,",
          "translation": "Then to Hrothgar was given success in battle,"
        },
        {
          "num": 65,
          "a": "wiges weorðmynd,",
          "b": "þæt him his winemagas",
          "translation": "honor in war, so that his kinsmen"
        },
        {
          "num": 66,
          "a": "georne hyrdon,",
          "b": "oðð þæt seo geogoð geweox,",
          "translation": "eagerly obeyed him, until the young troop grew,"
        },
        {
          "num": 67,
          "a": "magodriht micel.",
          "b": "Him on mod bearn",
          "translation": "a great band of young warriors. It came into his mind"
        },
        {
          "num": 68,
          "a": "þæt healreced",
          "b": "hatan wolde,",
          "translation": "that he would order a hall-building to be made,"
        },
        {
          "num": 69,
          "a": "medoærn micel",
          "b": "men gewyrcean",
          "translation": "a great mead-hall that men should construct,"
        },
        {
          "num": 70,
          "a": "þonne yldo bearn",
          "b": "æfre gefrunon,",
          "translation": "greater than the children of men had ever heard of,"
        },
        {
          "num": 71,
          "a": "ond þær on innan",
          "b": "eall gedælan",
          "translation": "and within it he would share out everything"
        },
        {
          "num": 72,
          "a": "geongum ond ealdum,",
          "b": "swylc him god sealde,",
          "translation": "to young and old, such as God gave him —"
        },
        {
          "num": 73,
          "a": "buton folcscare",
          "b": "ond feorum gumena.",
          "translation": "except for the common land and the lives of men."
        },
        {
          "num": 74,
          "a": "ða ic wide gefrægn",
          "b": "weorc gebannan",
          "translation": "Then I heard far and wide that work was commanded"
        },
        {
          "num": 75,
          "a": "manigre mægþe",
          "b": "geond þisne middangeard,",
          "translation": "of many a tribe throughout this middle-earth,"
        },
        {
          "num": 76,
          "a": "folcstede frætwan.",
          "b": "Him on fyrste gelomp,",
          "translation": "to adorn the folk-place. It came to pass in time,"
        },
        {
          "num": 77,
          "a": "ædre mid yldum,",
          "b": "þæt hit wearð ealgearo,",
          "translation": "swiftly among men, that it was fully ready,"
        },
        {
          "num": 78,
          "a": "healærna mæst;",
          "b": "scop him Heort naman",
          "translation": "the greatest of hall-buildings. He gave it the name Heorot."
        },
        {
          "num": 79,
          "a": "se þe his wordes geweald",
          "b": "wide hæfde.",
          "translation": "He whose word held sway far and wide."
        },
        {
          "num": 80,
          "a": "He beot ne aleh,",
          "b": "beagas dælde,",
          "translation": "He did not neglect his vow; he dealt out rings,"
        },
        {
          "num": 81,
          "a": "sinc æt symle.",
          "b": "Sele hlifade,",
          "translation": "treasure at the feast. The hall towered,"
        },
        {
          "num": 82,
          "a": "heah ond horngeap,",
          "b": "heaðowylma bad,",
          "translation": "high and wide-gabled, awaiting the hostile surges,"
        },
        {
          "num": 83,
          "a": "laðan liges;",
          "b": "ne wæs hit lenge þa gen",
          "translation": "the hateful flames — it was not yet long"
        },
        {
          "num": 84,
          "a": "þæt se ecghete",
          "b": "aþumsweorum",
          "translation": "before sword-hatred between son-in-law and father-in-law"
        },
        {
          "num": 85,
          "a": "æfter wælniðe",
          "b": "wæcnan scolde.",
          "translation": "after deadly enmity would be awakened."
        },
        {
          "num": 86,
          "a": "ða se ellengæst",
          "b": "earfoðlice",
          "translation": "Then the powerful spirit endured painfully"
        },
        {
          "num": 87,
          "a": "þrage geþolode",
          "b": "se þe in þystrum bad,",
          "translation": "the time, he who dwelt in darkness —"
        },
        {
          "num": 88,
          "a": "þæt he dogora gehwam",
          "b": "dream gehyrde",
          "translation": "that he heard joy each day"
        },
        {
          "num": 89,
          "a": "hludne in healle;",
          "b": "þær wæs hearpan sweg,",
          "translation": "loud in the hall. There was the sound of the harp,"
        },
        {
          "num": 90,
          "a": "swutol sang scopes.",
          "b": "Sægde se þe cuþe",
          "translation": "the clear song of the bard. He spoke who knew"
        },
        {
          "num": 91,
          "a": "frumsceaft fira",
          "b": "feorran reccan,",
          "translation": "how to tell from far back the first creation of men:"
        },
        {
          "num": 92,
          "a": "cwæð þæt se ælmihtiga",
          "b": "eorðan worh te,",
          "translation": "he said the Almighty made the earth,"
        },
        {
          "num": 93,
          "a": "wlitebeorhtne wang,",
          "b": "swa wæter bebugeð,",
          "translation": "the bright and beautiful land, as the water surrounds it,"
        },
        {
          "num": 94,
          "a": "gesette sigehreþig",
          "b": "sunnan ond monan",
          "translation": "set triumphant the sun and moon"
        },
        {
          "num": 95,
          "a": "leoman to leohte",
          "b": "landbuendum,",
          "translation": "as lights to illuminate the land-dwellers,"
        },
        {
          "num": 96,
          "a": "ond gefrætwade",
          "b": "foldan sceatas",
          "translation": "and adorned the regions of the earth"
        },
        {
          "num": 97,
          "a": "leomum ond leafum,",
          "b": "lif eac gesceop",
          "translation": "with branches and leaves, and created life also"
        },
        {
          "num": 98,
          "a": "cynna gehwylcum",
          "b": "þara ðe cwice hwyrfaþ.",
          "translation": "for every kind of creature that moves living."
        },
        {
          "num": 99,
          "a": "Swa ða drihtguman",
          "b": "dreamum lifdon,",
          "translation": "So those noble warriors lived in joy,"
        },
        {
          "num": 100,
          "a": "eadiglice,",
          "b": "oðþæt an ongan",
          "translation": "blessedly, until one began"
        },
        {
          "num": 101,
          "a": "fyren onþeon",
          "b": "se þe in þystrum bad,",
          "translation": "to commit crimes — one who dwelt in darkness:"
        },
        {
          "num": 102,
          "a": "wæs se grimma gæst",
          "b": "Grendel haten,",
          "translation": "the grim spirit was called Grendel,"
        },
        {
          "num": 103,
          "a": "mære mearcstapa,",
          "b": "se þe moras heold,",
          "translation": "the famous boundary-stalker, who held the moors,"
        },
        {
          "num": 104,
          "a": "fen ond fæsten;",
          "b": "fifelcynnes eard",
          "translation": "fens and fastness. The homeland of the monster-kin"
        },
        {
          "num": 105,
          "a": "wonsæli wer",
          "b": "weardode hwile,",
          "translation": "this wretched man guarded for a time,"
        },
        {
          "num": 106,
          "a": "siþðan him scyppend",
          "b": "forscrifen hæfde",
          "translation": "since the Creator had condemned him."
        },
        {
          "num": 107,
          "a": "in Caines cynne",
          "b": "þone cwealm gewræc",
          "translation": "On Cain's kin the eternal Lord avenged"
        },
        {
          "num": 108,
          "a": "ece drihten,",
          "b": "þæs þe he Abel slog;",
          "translation": "the killing — because he had slain Abel."
        },
        {
          "num": 109,
          "a": "ne gefeah he þære fæhðe,",
          "b": "ac he hine feor forwræc,",
          "translation": "He did not rejoice in that strife, but God drove him far away,"
        },
        {
          "num": 110,
          "a": "metod for þy mane",
          "b": "mancynne fram.",
          "translation": "the Measurer, for that crime, away from mankind."
        },
        {
          "num": 111,
          "a": "þanon untydras",
          "b": "ealle onwocon,",
          "translation": "From him all evil broods were born:"
        },
        {
          "num": 112,
          "a": "eotenas ond ylfe",
          "b": "ond orcneas,",
          "translation": "giants and elves and monsters,"
        },
        {
          "num": 113,
          "a": "swylce gigantas,",
          "b": "þa wið gode wunnon",
          "translation": "and likewise the giants who strove against God"
        },
        {
          "num": 114,
          "a": "lange þrage;",
          "b": "he him ðæs lean forgeald.",
          "translation": "for a long time. He paid them the reward for that."
        }
      ]
    },
    {
      "id": "fitt-3",
      "num": "III",
      "title": "Grendel's Ravages",
      "lineStart": 115,
      "lineEnd": 193,
      "lines": [
        {
          "num": 115,
          "a": "Gewat ða neosian,",
          "b": "syþðan niht becom,",
          "translation": "He went then to seek out, after night had come,"
        },
        {
          "num": 116,
          "a": "hean huses,",
          "b": "hu hit Hringdene",
          "translation": "the high house — how the Ring-Danes"
        },
        {
          "num": 117,
          "a": "æfter beorþege",
          "b": "gebun hæfdon.",
          "translation": "had settled in it after the beer-feast."
        },
        {
          "num": 118,
          "a": "Fand þa ðær inne",
          "b": "æþelinga gedriht",
          "translation": "He found there within a troop of noblemen"
        },
        {
          "num": 119,
          "a": "swefan æfter symble;",
          "b": "sorge ne cuðon,",
          "translation": "sleeping after the feast, knowing no sorrow,"
        },
        {
          "num": 120,
          "a": "wonsceaft wera.",
          "b": "Wiht unhælo,",
          "translation": "the misery of men. The creature of destruction,"
        },
        {
          "num": 121,
          "a": "grim ond grædig,",
          "b": "gearo sona wæs,",
          "translation": "fierce and ravenous, was ready at once:"
        },
        {
          "num": 122,
          "a": "reoc ond reþe,",
          "b": "ond on ræste genam",
          "translation": "savage and merciless, he seized from their rest"
        },
        {
          "num": 123,
          "a": "þritig þegna,",
          "b": "þanon eft gewat",
          "translation": "thirty thanes, and departed thence again"
        },
        {
          "num": 124,
          "a": "huðe hremig",
          "b": "to ham faran,",
          "translation": "exulting in his prey, to travel homeward,"
        },
        {
          "num": 125,
          "a": "mid þære wælfylle",
          "b": "wica neosan.",
          "translation": "with his fill of slaughter, to seek his dwelling."
        },
        {
          "num": 126,
          "a": "ða wæs on uhtan",
          "b": "mid ærdæge",
          "translation": "Then was in the hours before dawn, at daybreak,"
        },
        {
          "num": 127,
          "a": "Grendles guðcræft",
          "b": "gumum undyrne;",
          "translation": "Grendel's battle-strength revealed to men."
        },
        {
          "num": 128,
          "a": "þa wæs æfter wiste",
          "b": "wop up ahafen,",
          "translation": "Then after the feast a wailing was raised up,"
        },
        {
          "num": 129,
          "a": "micel morgensweg.",
          "b": "Mære þeoden,",
          "translation": "a great morning-cry. The famous ruler,"
        },
        {
          "num": 130,
          "a": "æþeling ærgod,",
          "b": "unbliðe sæt,",
          "translation": "the prince, excellent of old, sat joyless,"
        },
        {
          "num": 131,
          "a": "þolode ðryðswyð,",
          "b": "þegnsorge dreah",
          "translation": "suffered greatly, endured grief for his thanes,"
        },
        {
          "num": 132,
          "a": "syþðan hie þæs laðan",
          "b": "last sceawedon,",
          "translation": "after they had seen the track of the hated creature,"
        },
        {
          "num": 133,
          "a": "wergan gastes;",
          "b": "wæs þæt gewin to strang,",
          "translation": "of the accursed spirit. That strife was too severe,"
        },
        {
          "num": 134,
          "a": "laþ ond longsum.",
          "b": "Næs hit lengra fyrst,",
          "translation": "hateful and prolonged. It was not a longer period,"
        },
        {
          "num": 135,
          "a": "ac ymb ane niht",
          "b": "eft gefremede",
          "translation": "but after one night he again committed"
        },
        {
          "num": 136,
          "a": "morðbeala mare,",
          "b": "ond no mearn fore,",
          "translation": "greater murderous evil, and did not grieve for it:"
        },
        {
          "num": 137,
          "a": "fæhðe ond fyrene;",
          "b": "wæs to fæst on þam.",
          "translation": "acts of feud and crime — he was too set in those ways."
        },
        {
          "num": 138,
          "a": "þa wæs eaðfynde",
          "b": "þe him elles hwær",
          "translation": "Then it was easily found who sought elsewhere"
        },
        {
          "num": 139,
          "a": "gerumlicor",
          "b": "ræste sohte,",
          "translation": "a more spacious resting place"
        },
        {
          "num": 140,
          "a": "bed æfter burum,",
          "b": "ða him gebeacnod wæs,",
          "translation": "a bed in the outbuildings, when it was shown to him"
        },
        {
          "num": 141,
          "a": "gesægd soðlice",
          "b": "sweotolan tacne",
          "translation": "told truly with clear sign —"
        },
        {
          "num": 142,
          "a": "healðegnes hete;",
          "b": "heold hyne syþðan",
          "translation": "the hall-thane's hatred. He who henceforth kept"
        },
        {
          "num": 143,
          "a": "fyr ond fæstor",
          "b": "se þæm feonde ætwand.",
          "translation": "farther off and safer — he who escaped the fiend."
        },
        {
          "num": 144,
          "a": "Swa rixode",
          "b": "ond wið rihte wan,",
          "translation": "So he ruled and strove against what was right:"
        },
        {
          "num": 145,
          "a": "ana wið eallum,",
          "b": "oðþæt idel stod",
          "translation": "one against all, until stood empty"
        },
        {
          "num": 146,
          "a": "þæt æþele traef.",
          "b": "Wæs seo hwil micel:",
          "translation": "that splendid hall. The time was great:"
        },
        {
          "num": 147,
          "a": "XII wintra tid",
          "b": "torn geþolode",
          "translation": "twelve winters' time the lord of the Scyldings"
        },
        {
          "num": 148,
          "a": "wine Scyldinga,",
          "b": "weana gehwelcne,",
          "translation": "endured affliction, every woe,"
        },
        {
          "num": 149,
          "a": "sidra sorga;",
          "b": "forðam secgum wearð,",
          "translation": "boundless sorrows. Therefore it became known to men,"
        },
        {
          "num": 150,
          "a": "ylda bearnum,",
          "b": "undyrne cuð,",
          "translation": "to the children of men, openly revealed"
        },
        {
          "num": 151,
          "a": "gyddum geomore,",
          "b": "þætte Grendel wan",
          "translation": "through mournful songs, that Grendel waged war"
        },
        {
          "num": 152,
          "a": "hwile wið Hrothgar,",
          "b": "heteniðas wæg,",
          "translation": "for a time against Hrothgar, bore hateful enmity,"
        },
        {
          "num": 153,
          "a": "fyrene ond fæhðe",
          "b": "fela missera,",
          "translation": "crime and feud, for many seasons,"
        },
        {
          "num": 154,
          "a": "singale sæce;",
          "b": "sibbe ne wolde",
          "translation": "perpetual conflict. He would have no peace"
        },
        {
          "num": 155,
          "a": "wið manna hwone",
          "b": "megenes Deniga,",
          "translation": "with any man among the Danes' forces,"
        },
        {
          "num": 156,
          "a": "ne his myne wisse,",
          "b": "ne þær nænig witena",
          "translation": "nor remove his murderous intent, nor would any councillor there"
        },
        {
          "num": 157,
          "a": "wenan þorfte",
          "b": "beorhtre bote",
          "translation": "need to expect bright redress"
        },
        {
          "num": 158,
          "a": "to ðan banan folmum,",
          "b": "þær wæs bealo benne,",
          "translation": "from the killer's hands — the monster's wound was dark,"
        },
        {
          "num": 159,
          "a": "þær wæs Hroðgare",
          "b": "hearm ætforan,",
          "translation": "Hrothgar's harm was directly before him,"
        },
        {
          "num": 160,
          "a": "yrre ond aglæc.",
          "b": "Nið wæs niowe,",
          "translation": "wrath and affliction. Enmity was constant,"
        },
        {
          "num": 161,
          "a": "nihtbealwa mæst,",
          "b": "þe him Grendel sceop.",
          "translation": "the greatest of night-evils, that Grendel wrought against him."
        },
        {
          "num": 162,
          "a": "Hwilum hie geheton",
          "b": "æt hærgtrafum",
          "translation": "Sometimes they made vows at their idol-shrines,"
        },
        {
          "num": 163,
          "a": "wigweorþunga,",
          "b": "wordum bædon",
          "translation": "honored their idols, prayed in words"
        },
        {
          "num": 164,
          "a": "þæt him gastbona",
          "b": "geoce gefremede",
          "translation": "that the soul-slayer would bring them help"
        },
        {
          "num": 165,
          "a": "wið þeodþreaum.",
          "b": "Hwylc wæs þeaw hyra,",
          "translation": "against their people's terror. Such was their custom:"
        },
        {
          "num": 166,
          "a": "hæþen hæft,",
          "b": "hell gemundon",
          "translation": "heathen hope — they thought of hell"
        },
        {
          "num": 167,
          "a": "in modsefan,",
          "b": "metod hie ne cuþon,",
          "translation": "in their minds. They did not know the Creator,"
        },
        {
          "num": 168,
          "a": "dæda demend,",
          "b": "ne wiston hie drihten god,",
          "translation": "the Judge of deeds, they did not know the Lord God;"
        },
        {
          "num": 169,
          "a": "ne hie huru heofena helm",
          "b": "herian ne cuþon,",
          "translation": "indeed they could not praise the Protector of the heavens,"
        },
        {
          "num": 170,
          "a": "wuldres waldend.",
          "b": "Wa bið þæm ðe sceal",
          "translation": "the Ruler of glory. Woe is to him who must"
        },
        {
          "num": 171,
          "a": "þurh sliðne nið",
          "b": "sawle bescufan",
          "translation": "thrust his soul through terrible malice"
        },
        {
          "num": 172,
          "a": "in fyres fæþm,",
          "b": "frofre ne wenan,",
          "translation": "into the fire's embrace — not expect comfort,"
        },
        {
          "num": 173,
          "a": "wihte gewendan;",
          "b": "wel bið þæm þe mot",
          "translation": "change in any way. Well is it for him who may"
        },
        {
          "num": 174,
          "a": "æfter deaðdæge",
          "b": "drihten secean",
          "translation": "after his day of death seek the Lord"
        },
        {
          "num": 175,
          "a": "ond to fæder fæþmum",
          "b": "freoðo wilnian.",
          "translation": "and ask for peace in the Father's embrace."
        },
        {
          "num": 176,
          "a": "Swa ða mælceare",
          "b": "maga Healfdenes",
          "translation": "So the son of Healfdene brooded on his time of sorrow,"
        },
        {
          "num": 177,
          "a": "singala seað;",
          "b": "ne mihte snotor hæleð",
          "translation": "continually seethed. The wise hero could not"
        },
        {
          "num": 178,
          "a": "wean onwendan;",
          "b": "wæs þæt gewin to swið,",
          "translation": "ward off the misery. That strife was too great,"
        },
        {
          "num": 179,
          "a": "laþ ond longsum,",
          "b": "þe on ða leode becom,",
          "translation": "hateful and enduring, that came upon that people,"
        },
        {
          "num": 180,
          "a": "nydwracu niþgrim,",
          "b": "nihtbealwa mæst.",
          "translation": "fierce forced oppression, the greatest of night-evils."
        },
        {
          "num": 181,
          "a": "þæt fram ham gefrægn",
          "b": "Higelaces þegn,",
          "translation": "A thane of Hygelac heard of this from home:"
        },
        {
          "num": 182,
          "a": "god mid Geatum,",
          "b": "Grendles dæda;",
          "translation": "good among the Geats, of Grendel's deeds."
        },
        {
          "num": 183,
          "a": "se wæs moncynnes",
          "b": "mægenes strengest",
          "translation": "He was of mankind the strongest in might"
        },
        {
          "num": 184,
          "a": "on þæm dæge",
          "b": "þysses lifes,",
          "translation": "in that day of this life,"
        },
        {
          "num": 185,
          "a": "æþele ond eacen.",
          "b": "Het him yðlidan",
          "translation": "noble and great. He commanded a good ship to be made ready for him;"
        },
        {
          "num": 186,
          "a": "godne gegyrwan;",
          "b": "cwæð he guðcyning",
          "translation": "said he the warrior-king"
        },
        {
          "num": 187,
          "a": "ofer swanrade",
          "b": "secean wolde,",
          "translation": "over the swan-road would seek,"
        },
        {
          "num": 188,
          "a": "mærne þeoden,",
          "b": "þa him wæs manna þearf.",
          "translation": "the famous ruler, since he had need of men."
        },
        {
          "num": 189,
          "a": "ðone siðfæt him",
          "b": "snotere ceorlas",
          "translation": "That expedition the wise men"
        },
        {
          "num": 190,
          "a": "lythwon logon,",
          "b": "þeah he him leof wære;",
          "translation": "little blamed, though he was dear to them."
        },
        {
          "num": 191,
          "a": "hwetton higerofne,",
          "b": "hæl sceawedon.",
          "translation": "They urged on the courageous man, observed the omens."
        },
        {
          "num": 192,
          "a": "Hæfde se goda",
          "b": "Geata leoda",
          "translation": "The good man had chosen from the Geatish people"
        },
        {
          "num": 193,
          "a": "cempan gecorone,",
          "b": "þa þe him cenoste",
          "translation": "chosen champions, the keenest that he could find."
        }
      ]
    }
  ]
}
